{
  "name": "contextqmd",
  "version": "0.2.8",
  "description": "Local-first docs CLI for AI agents: install, search, and read library documentation",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/contextqmd/contextqmd-cli.git"
  },
  "keywords": [
    "documentation",
    "docs",
    "context",
    "contextqmd",
    "ai",
    "search",
    "local-first",
    "cli"
  ],
  "type": "module",
  "files": [
    "dist"
  ],
  "bin": {
    "contextqmd": "dist/index.js"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json && chmod +x dist/index.js",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "check": "tsc --noEmit",
    "link": "npm link"
  },
  "dependencies": {
    "@tobilu/qmd": "^2.0.1",
    "commander": "^14.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
